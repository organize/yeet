{
  "name": "yeet",
  "version": "0.1.0",
  "description": "Generator-based Either monad for TypeScript",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "bench": "vitest bench --run && bun run scripts/bench-to-csv.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "bun run src/index.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "better-result": "2.7.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
